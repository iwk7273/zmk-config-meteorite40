#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/keys.h>
/*
 * keys.h pulls in modifiers.h, whose RC(keycode) (right-control) macro shadows
 * matrix_transform.h's RC(row, col) used by the shield keymap transforms.
 * Restore the transform macro here; the ball router bindings below use only
 * LC/LG/LA, never RC. (Keymaps include keys.h in their own translation unit and
 * do not use right-control RC(), so they are unaffected.)
 */
#undef RC
#define RC(row, col) (((row) << 8) + (col))
#include <input/processors.dtsi>

#define DEFAULT_CPI 800         // トラックボールの感度
#define ROTATION_ANGLE 20       // トラックボールのY軸を回転
#define CLIPPER_THRESHOLD 20    // スクロール時に斜めの値をクリップ

// Ball Profile 値（enum zmk_ball_profile / zmk.meteorite.BallProfile と一致させること）
#define BALL_OFF 0
#define BALL_SCROLL 1
#define BALL_SENS_NORMAL 2
#define INVERT_X 0              // X軸のスクロールの反転
#define INVERT_Y 0              // Y軸のスクロールの反転

#define SCALING_MODE 1          // 0: 無効, 1: 有効
#define SCROLL_SCALING_MODE 0   // 0: 無効, 1: 有効
#define OS_MODE_DEFAULT 0       // 0: Win, 1: Mac
#define MAX_OUTPUT 300          // 出力の最大絶対値 |y|。既定 127
#define HALF_INPUT 50           // r=|x|/xs の xs（counts）。既定 50
#define EXPONENT_TENTHS 12      // 指数 p を 0.1 分解能で指定（p*10、例: 15 は p=1.5）。既定 10（p=1.0）

#define SCROLL_MAX_OUTPUT 300
#define SCROLL_HALF_INPUT 55
#define SCROLL_EXPONENT_TENTHS 6  // p = 0.6

#define POLL_PERIOD_MS 15       // キースキャンのポーリング周期（ms）
#define DEBOUNCE_MS 10           // デバウンス時間 (ms)

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    cs-gpios = <&gpio1 15 GPIO_ACTIVE_LOW>; // CS: P1.15

    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";

    trackball: pmw3610@0 {
        compatible = "pixart,pmw3610-custom";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio1 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; // MOTION: P1.12
        cpi = <DEFAULT_CPI>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
        force-awake;
        //force-awake-4ms-mode;
        status = "okay";
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 13)>,   // SCLK:  P1.13
                    <NRF_PSEL(SPIM_MOSI, 1, 14)>,  // SDIO:  P1.14
                    <NRF_PSEL(SPIM_MISO, 1, 14)>;  // MISOは同じSDIO兼用
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 13)>,
                    <NRF_PSEL(SPIM_MOSI, 1, 14)>,
                    <NRF_PSEL(SPIM_MISO, 1, 14)>;
            low-power-enable;
        };
    };
};

/ {
    meteorite40_scan: kscan0 {
        compatible = "zmk,kscan-gpio-charlieplex";
        gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>,  // ID0: P0.02
                <&gpio0 3 GPIO_ACTIVE_HIGH>,  // ID1: P0.03
                <&gpio0 28 GPIO_ACTIVE_HIGH>, // ID2: P0.28
                <&gpio0 29 GPIO_ACTIVE_HIGH>, // ID3: P0.29
                <&gpio0 4 GPIO_ACTIVE_HIGH>,  // ID4: P0.04
                <&gpio0 5 GPIO_ACTIVE_HIGH>,  // ID5: P0.05
                <&gpio1 11 GPIO_ACTIVE_HIGH>; // ID6: P1.11

        interrupt-gpios = <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>; // Changed to P0.09 (NFC1)
        debounce-press-ms = <DEBOUNCE_MS>;
        debounce-release-ms = <DEBOUNCE_MS>;
        poll-period-ms = <POLL_PERIOD_MS>;
        wakeup-source;
    };

    encoder0: ec11_0 {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 0 (GPIO_ACTIVE_LOW   | GPIO_PULL_UP)>;   // RE0_A: P1.00
        b-gpios = <&gpio0 16 (GPIO_ACTIVE_LOW   | GPIO_PULL_UP)>;  // RE0_B: P0.16
        steps = <96>;
        status = "okay";
    };

    encoder1: ec11_1 {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 10 (GPIO_ACTIVE_LOW   | GPIO_PULL_UP)>;  // RE1_A: P0.10 (NFC2)
        b-gpios = <&gpio1 10 (GPIO_ACTIVE_LOW   | GPIO_PULL_UP)>;  // RE1_B: P1.10
        steps = <96>;
        status = "okay";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder0 &encoder1>;
        triggers-per-rotation = <24>;
    };

    /*
    xy_transf: xy_transf {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
        type = <INPUT_EV_REL>;
        x-codes = <INPUT_REL_X>, <INPUT_REL_WHEEL>;
        y-codes = <INPUT_REL_Y>, <INPUT_REL_HWHEEL>;
    };

    xy_scaler: xy_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_X>, <INPUT_REL_Y>;
        track-remainders;
    };

    x_scaler: x_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_X>;
    };
    */

    to_wheel: to_wheel {
        compatible = "zmk,input-processor-code-mapper";
        #input-processor-cells = <0>;
        type = <INPUT_EV_REL>;
        map = <INPUT_REL_X INPUT_REL_HWHEEL>,
              <INPUT_REL_Y INPUT_REL_WHEEL>;
    };

    motion_scaler: motion_scaler {
        compatible = "zmk,input-processor-meteorite-motion-scaler";
        #input-processor-cells = <0>;
        custom-config-scaling = <0>;
        scaling-mode = <SCALING_MODE>;
        max-output = <MAX_OUTPUT>;
        half-input = <HALF_INPUT>;
        exponent-tenths = <EXPONENT_TENTHS>;
        track-remainders;
    };

    scroll_motion_scaler: motion_scaler_scroll {
        compatible = "zmk,input-processor-meteorite-motion-scaler";
        #input-processor-cells = <0>;
        custom-config-scaling = <1>;
        scaling-mode = <SCROLL_SCALING_MODE>;
        max-output = <SCROLL_MAX_OUTPUT>;
        half-input = <SCROLL_HALF_INPUT>;
        exponent-tenths = <SCROLL_EXPONENT_TENTHS>;
        //track-remainders;
    };

    sensor_rotation: sensor_rotation {
        compatible = "zmk,input-processor-meteorite-sensor-rotation";
        #input-processor-cells = <0>;
        rotation-angle = <ROTATION_ANGLE>;
    };

    xy_clipper: xy_clipper {
        compatible = "zmk,input-processor-meteorite-xy-clipper";
        #input-processor-cells = <0>;
        threshold = <CLIPPER_THRESHOLD>;
        invert-x = <INVERT_X>;
        invert-y = <INVERT_Y>;
    };

    /*
     * NOTE: これらのノードを #if CONFIG_ZMK_CUSTOM_CONFIG で囲ってはいけない。
     * Zephyr は devicetree のプリプロセスを Kconfig より先に実行するため、DTS
     * 内では CONFIG_* マクロが未定義（=偽）になり、ノードごと DT から除外され、
     * default 値が一切読めなくなる（ZMK 自身も dtsi 内で #if CONFIG_ を使わない）。
     */
    ball_profile_defaults: ball_profile_defaults {
        compatible = "zmk,ball-profile-defaults";
        /* レイヤ index 順: 0=BASE 1=SYMBOLS 2=NUM/ARROW 3=FUNCTION 4=SETTING。
         * デフォルト: Layer 2 (NUM/ARROW) のみ SCROLL、他は OFF。 */
        layer-profiles = <BALL_OFF BALL_OFF BALL_SCROLL BALL_OFF BALL_OFF>;
        sensitivity = <BALL_SENS_NORMAL>;
    };

    custom_config_defaults: custom_config_defaults {
        compatible = "zmk,custom-config-defaults";
        os-mode = <OS_MODE_DEFAULT>;
        idle-timeout-s = <120>;
        idle-sleep-timeout-s = <900>;
    };

    behaviors {
        /* Ball Profile 専用の OS キー（keymap の &mosk とは別インスタンスにして
         * pressed 状態を共有しない）。param 0 はそのOSで no-op。 */
        ball_mosk: ball_mosk {
            compatible = "zmk,behavior-meteorite-os-key";
            #binding-cells = <2>;
            display-name = "Ball OS-Switch Key";
        };
    };

    ball_profile_router: ball_profile_router {
        compatible = "zmk,input-processor-meteorite-ball-profile";
        #input-processor-cells = <0>;
        /* SCROLL profile のサブチェーン（現挙動を踏襲） */
        input-processors = <&xy_clipper>,
                           <&scroll_motion_scaler>,
                           <&to_wheel>;
        /* 固定 Profile の 12 binding（profile-major / 方向 LEFT,RIGHT,UP,DOWN）。
         * &ball_mosk <Win> <Mac>（0 = そのOSで no-op）、OS非依存は &kp。
         * ズームは consumer の C_AC_ZOOM_IN/OUT だとブラウザ/OS が反応しないため、
         * 確実に効く Ctrl/⌘ + = / - を使う。 */
        bindings =
            /* BROWSER */
            <&ball_mosk LC(PG_UP) LG(LA(LEFT))>,
            <&ball_mosk LC(PG_DN) LG(LA(RIGHT))>,
            <&ball_mosk LC(EQUAL) LG(EQUAL)>,
            <&ball_mosk LC(MINUS) LG(MINUS)>,
            /* DESKTOP */
            <&ball_mosk LC(LG(LEFT)) LC(LEFT)>,
            <&ball_mosk LC(LG(RIGHT)) LC(RIGHT)>,
            <&ball_mosk LG(TAB) LC(UP)>,
            <&ball_mosk LG(D) F11>,
            /* WINDOW（Mac: System Settings > Keyboard Shortcuts > App Shortcuts で
             * 「Window > Move & Resize > Left/Right/Fill」に Ctrl+Opt+←/→/↑ を設定） */
            <&ball_mosk LG(LEFT) LC(LA(LEFT))>,
            <&ball_mosk LG(RIGHT) LC(LA(RIGHT))>,
            <&ball_mosk LG(UP) LC(LA(UP))>,
            <&ball_mosk LG(DOWN) LC(LA(DOWN))>;
    };

    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;

        input-processors = <&sensor_rotation>,
                           <&ball_profile_router>,
                           <&motion_scaler>;
    };
};
